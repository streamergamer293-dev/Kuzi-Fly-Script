	b.Size = UDim2.new(1,-20,0,40)
	b.Position = UDim2.new(0,10,0,y)
	b.Text = txt
	b.BackgroundColor3 = Color3.fromRGB(80,0,150)
	b.TextColor3 = Color3.new(1,1,1)
	b.MouseButton1Click:Connect(func)
end

button("TP 1",10,function() ninjaTP(saves[1]) end)
button("TP 2",60,function() ninjaTP(saves[2]) end)
button("TP 3",110,function() ninjaTP(saves[3]) end)
